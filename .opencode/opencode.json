{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "ask",
      "grep *": "allow",
      "gh *": "allow",
      "idf.py *": "allow",
      ". ~/.espressif/*/esp-idf/export.sh && *": "allow",
      "~/.espressif/*/esp-idf/*": "allow"
    },
    "read": "allow",
    "write": "allow",
    "edit": "allow"
  },
  "watcher": {
    "ignore": [
      "build/**",
      "sdkconfig*",
      "**/deps/**",
      "third_party/OPL_Kicad_Library/**"
    ]
  },
  "instructions": [
    "AGENTS.md",
    ".agents/**/*.md"
  ]
}
