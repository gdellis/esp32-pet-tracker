{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "cargo *": "allow",
      "espflash *": "allow",
      "rustup *": "allow",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      ". ~/export-esp.sh":"allow"
    },
    "task": "ask",
    "skill": "ask",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "~/.espressif": "allow",
      "~/.rustup/toolchains":"allow"
    }
  }
}
